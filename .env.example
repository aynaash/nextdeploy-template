# Neon Postgres connection string — https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# better-auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# The public URL your app is served from.
#   dev:  http://localhost:3000
#   prod: https://your-domain.com  (also used for metadata, sitemap, OG image,
#         and the Server Actions allowed-origin check)
BETTER_AUTH_URL="http://localhost:3000"
